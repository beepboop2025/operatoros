# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://operatoros:operatoros@postgres:5432/operatoros

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key
EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_LLM_MODEL=anthropic/claude-sonnet-4.6
# LLM_MODEL_OVERRIDE=meta-llama/llama-3.3-70b-instruct:free  # free model for credit-less deploys

# ── Free LLM router (perpetually-free providers) ───────────────────────────────
# Cheap tasks (classification/factual/bulk) use these first; paid is the fallback.
# Set any subset — the router only uses providers whose key is present.
FREE_LLM_ENABLED=true
GROQ_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
MISTRAL_API_KEY=

# ── Supabase (optional - only if using Supabase cloud) ───────────────────────
SUPABASE_URL=optional-if-using-supabase-cloud
SUPABASE_KEY=optional-if-using-supabase-cloud

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://n8n:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ── Notifications (optional) ──────────────────────────────────────────────────
# Outbound alerts for new waitlist signups. Leave blank to disable a channel —
# in-app bell notifications work regardless. Delivery runs in the Celery worker.
# Email (SMTP):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
NOTIFY_EMAIL_TO=                       # e.g. you@yourdomain.com (comma-separated for many)
# Telegram (create a bot via @BotFather, get chat id via @userinfobot):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Production only ───────────────────────────────────────────────────────────
# Uncomment + set these for a real deployment (docker-compose.prod.yml).
# ENVIRONMENT=production
# LOG_LEVEL=INFO
# DOMAIN=yourdomain.com
# SECRET_KEY=<run: python -c "import secrets; print(secrets.token_hex(32))">
# CORS_ORIGINS=https://app.yourdomain.com
#
# Redis requires a password in prod (compose runs redis with --requirepass).
# These THREE must all use the SAME password or the app and Celery cannot connect:
# REDIS_PASSWORD=<strong-password>
# REDIS_URL=redis://:<strong-password>@redis:6379/0
# CELERY_BROKER_URL=redis://:<strong-password>@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:<strong-password>@redis:6379/0
